// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`generateFishCompletions > matches snapshot 1`] = `
"# Fish completions for mycli
# Generated by @runa-cmd/completions

complete -c mycli -f

# Global options
complete -c mycli -l help -s h -d 'Show help'
complete -c mycli -l no-help -d 'Show help'
complete -c mycli -l verbose -s v -d 'Enable verbose output'
complete -c mycli -l no-verbose -d 'Enable verbose output'
complete -c mycli -l format -d 'Output format' -r -a 'json text table'

# Commands
complete -c mycli -n '__fish_use_subcommand' -a 'deploy' -d 'Deploy the app'
complete -c mycli -n '__fish_seen_subcommand_from deploy' -l environment -s e -d 'Target environment' -r -a 'staging prod'
complete -c mycli -n '__fish_seen_subcommand_from deploy' -l force -d 'Force deploy without confirmation'
complete -c mycli -n '__fish_seen_subcommand_from deploy' -l no-force -d 'Force deploy without confirmation'
complete -c mycli -n '__fish_seen_subcommand_from deploy' -l replicas -d 'Number of replicas' -r
complete -c mycli -n '__fish_use_subcommand' -a 'config' -d 'Manage configuration'
complete -c mycli -n '__fish_seen_subcommand_from config' -a 'set' -d 'Set a config value'
complete -c mycli -n '__fish_seen_subcommand_from set' -l global -s g -d 'Set globally'
complete -c mycli -n '__fish_seen_subcommand_from set' -l no-global -d 'Set globally'
complete -c mycli -n '__fish_seen_subcommand_from config' -a 'get' -d 'Get a config value'"
`;
