// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`generateZshCompletions > matches snapshot 1`] = `
"#compdef mycli
# Zsh completions for mycli
# Generated by @runa-cmd/completions

_mycli() {
    local -a commands
    local state line

    _arguments -C \\
        '(-h --help)'{-h,--help}'[Show help]' \\
        '--no-help[Show help]' \\
        '(-v --verbose)'{-v,--verbose}'[Enable verbose output]' \\
        '--no-verbose[Enable verbose output]' \\
        '--format[Output format]:format:(json text table)' \\
        '1:command:->cmds' \\
        '*::arg:->args'

    case "$state" in
        cmds)
            commands=(
                'deploy:Deploy the app'
                'config:Manage configuration'
            )
            _describe 'command' commands
            ;;
        args)
            case "$line[1]" in
                deploy)
                    _mycli_deploy
                    ;;
                config)
                    _mycli_config
                    ;;
            esac
            ;;
    esac
}

_mycli_deploy() {
    _arguments \\
        '(-h --help)'{-h,--help}'[Show help]' \\
        '--no-help[Show help]' \\
        '(-v --verbose)'{-v,--verbose}'[Enable verbose output]' \\
        '--no-verbose[Enable verbose output]' \\
        '--format[Output format]:format:(json text table)' \\
        '(-e --environment)'{-e,--environment}'[Target environment]:environment:(staging prod)' \\
        '--force[Force deploy without confirmation]' \\
        '--no-force[Force deploy without confirmation]' \\
        '--replicas[Number of replicas]:replicas:'
}

_mycli_config() {
    local -a commands
    local state line

    _arguments -C \\
        '(-h --help)'{-h,--help}'[Show help]' \\
        '--no-help[Show help]' \\
        '(-v --verbose)'{-v,--verbose}'[Enable verbose output]' \\
        '--no-verbose[Enable verbose output]' \\
        '--format[Output format]:format:(json text table)' \\
        '1:command:->cmds' \\
        '*::arg:->args'

    case "$state" in
        cmds)
            commands=(
                'set:Set a config value'
                'get:Get a config value'
            )
            _describe 'command' commands
            ;;
        args)
            case "$line[1]" in
                set)
                    _mycli_config_set
                    ;;
                get)
                    _mycli_config_get
                    ;;
            esac
            ;;
    esac
}

_mycli_config_set() {
    _arguments \\
        '(-h --help)'{-h,--help}'[Show help]' \\
        '--no-help[Show help]' \\
        '(-v --verbose)'{-v,--verbose}'[Enable verbose output]' \\
        '--no-verbose[Enable verbose output]' \\
        '--format[Output format]:format:(json text table)' \\
        '(-g --global)'{-g,--global}'[Set globally]' \\
        '--no-global[Set globally]'
}

_mycli_config_get() {
    _arguments \\
        '(-h --help)'{-h,--help}'[Show help]' \\
        '--no-help[Show help]' \\
        '(-v --verbose)'{-v,--verbose}'[Enable verbose output]' \\
        '--no-verbose[Enable verbose output]' \\
        '--format[Output format]:format:(json text table)'
}

_mycli"
`;
