// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`generateBashCompletions > matches snapshot 1`] = `
"#!/usr/bin/env bash
# Bash completions for mycli
# Generated by @runa-cmd/completions

_mycli_completions() {
    local cur="\${COMP_WORDS[COMP_CWORD]}"
    local prev="\${COMP_WORDS[COMP_CWORD-1]}"

    # Build command path from COMP_WORDS
    local cmd_path=""
    local i=1
    while [[ $i -lt $COMP_CWORD ]]; do
        case "\${COMP_WORDS[i]}" in
            -*) ;;
            *) cmd_path="\${cmd_path}_\${COMP_WORDS[i]}" ;;
        esac
        ((i++))
    done

    case "$cmd_path" in
        "")
            case "$prev" in
            --format)
                COMPREPLY=($(compgen -W 'json text table' -- "$cur"))
                return ;;
            esac
            if [[ "$cur" == -* ]]; then
                COMPREPLY=($(compgen -W '--help --no-help -h --verbose --no-verbose -v --format' -- "$cur"))
            else
                COMPREPLY=($(compgen -W 'deploy config' -- "$cur"))
            fi
            ;;
        "_deploy")
            case "$prev" in
            --environment|-e)
                COMPREPLY=($(compgen -W 'staging prod' -- "$cur"))
                return ;;
            --format)
                COMPREPLY=($(compgen -W 'json text table' -- "$cur"))
                return ;;
            esac
            if [[ "$cur" == -* ]]; then
                COMPREPLY=($(compgen -W '--environment -e --force --no-force --replicas --help --no-help -h --verbose --no-verbose -v --format' -- "$cur"))
            fi
            ;;
        "_config")
            case "$prev" in
            --format)
                COMPREPLY=($(compgen -W 'json text table' -- "$cur"))
                return ;;
            esac
            if [[ "$cur" == -* ]]; then
                COMPREPLY=($(compgen -W '--help --no-help -h --verbose --no-verbose -v --format' -- "$cur"))
            else
                COMPREPLY=($(compgen -W 'set get' -- "$cur"))
            fi
            ;;
        "_config_set")
            case "$prev" in
            --format)
                COMPREPLY=($(compgen -W 'json text table' -- "$cur"))
                return ;;
            esac
            if [[ "$cur" == -* ]]; then
                COMPREPLY=($(compgen -W '--global --no-global -g --help --no-help -h --verbose --no-verbose -v --format' -- "$cur"))
            fi
            ;;
        "_config_get")
            case "$prev" in
            --format)
                COMPREPLY=($(compgen -W 'json text table' -- "$cur"))
                return ;;
            esac
            if [[ "$cur" == -* ]]; then
                COMPREPLY=($(compgen -W '--help --no-help -h --verbose --no-verbose -v --format' -- "$cur"))
            fi
            ;;
    esac
}
complete -F _mycli_completions mycli"
`;
