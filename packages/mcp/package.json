{
	"name": "@runa-cmd/mcp",
	"version": "0.2.0-beta.0",
	"description": "MCP (Model Context Protocol) server mode for Runa CLIs. Turn commands into AI-callable tools.",
	"license": "MIT",
	"type": "module",
	"keywords": [
		"cli",
		"mcp",
		"model-context-protocol",
		"ai",
		"llm",
		"tools",
		"runa"
	],
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch --preserveWatchOutput",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0"
	},
	"peerDependencies": {
		"@runa-cmd/core": "^0.2.0-beta.0",
		"zod": "^4.0.0"
	},
	"engines": {
		"node": ">=24.0.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/jrodrigopuca/runa-cmd.git",
		"directory": "packages/mcp"
	},
	"homepage": "https://github.com/jrodrigopuca/runa-cmd/tree/main/packages/mcp#readme",
	"bugs": {
		"url": "https://github.com/jrodrigopuca/runa-cmd/issues"
	},
	"files": [
		"dist",
		"README.md"
	],
	"devDependencies": {
		"@runa-cmd/core": "workspace:*",
		"@types/node": "^25.6.0",
		"typescript": "^6.0.2",
		"zod": "^4.3.6"
	}
}
