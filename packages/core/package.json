{
	"name": "@runa-cmd/core",
	"version": "0.1.0",
	"description": "Schema-driven, TypeScript-first CLI engine — commands, parsing, plugins, middleware. Zero runtime deps.",
	"license": "MIT",
	"type": "module",
	"keywords": [
		"cli",
		"command-line",
		"zod",
		"typescript",
		"schema-driven",
		"parseargs",
		"plugin",
		"middleware"
	],
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./zod": {
			"types": "./dist/zod.d.ts",
			"import": "./dist/zod.js"
		}
	},
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch --preserveWatchOutput",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"clean": "rm -rf dist"
	},
	"peerDependencies": {
		"zod": "^4.0.0"
	},
	"engines": {
		"node": ">=24.0.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/jrodrigopuca/runa-cmd.git",
		"directory": "packages/core"
	},
	"homepage": "https://github.com/jrodrigopuca/runa-cmd/tree/main/packages/core#readme",
	"bugs": {
		"url": "https://github.com/jrodrigopuca/runa-cmd/issues"
	},
	"files": [
		"dist",
		"README.md"
	],
	"devDependencies": {
		"@types/node": "^25.6.0",
		"typescript": "^6.0.2",
		"zod": "^4.3.6"
	}
}
